@model JDSP.ViewModels.Cases.MyCasesViewModel
@{ Layout = "_ClientLayout"; ViewData["Title"] = "My cases"; string Active(string? s) => (string.IsNullOrWhiteSpace(s) && string.IsNullOrWhiteSpace(Model.StatusFilter)) || string.Equals(s, Model.StatusFilter, StringComparison.OrdinalIgnoreCase) ? "active" : ""; }

<div class="page-head"><span class="eyebrow">Case status</span><h1>My cases</h1><p>Official cases created and assigned to you by a Court Employee. This area is view-only for clients.</p></div>
@if (TempData["SuccessMessage"] != null) { <div class="alert alert-success">@TempData["SuccessMessage"]</div> }
<div class="filters"><a class="@Active(null)" asp-action="MyCases">All</a><a class="@Active("Open")" asp-action="MyCases" asp-route-status="Open">Open</a><a class="@Active("Pending")" asp-action="MyCases" asp-route-status="Pending">Pending</a><a class="@Active("In Progress")" asp-action="MyCases" asp-route-status="In Progress">In progress</a><a class="@Active("Closed")" asp-action="MyCases" asp-route-status="Closed">Closed</a></div>
@if (Model.Cases.Count == 0) {
    <div class="card-panel empty"><b>▣</b><h3>No official cases found</h3><p>Only a Court Employee can create a case and assign it to your account. You can contact a lawyer or post a public request while waiting.</p><div class="d-flex justify-content-center flex-wrap gap-2"><a asp-controller="Lawyers" asp-action="Index" class="btn btn-primary">Find lawyer</a><a asp-controller="ServiceRequests" asp-action="CreatePublic" class="btn btn-outline-primary">Public request</a></div></div>
}
else {
    <div class="row g-4">
    @foreach (var item in Model.Cases) {
        <div class="col-md-6 col-xl-4"><article class="case-card"><div class="d-flex justify-content-between"><b class="case-icon">▣</b><span class="status @item.Status.ToLower().Replace(" ", "-")">@item.Status</span></div><h2>@item.CaseName</h2><small class="case-type">@item.CaseType</small><p class="case-desc">@item.Description</p><div class="case-meta"><div><span>Assigned lawyer</span><strong>@(item.AssignedLawyerName ?? "Not assigned")</strong></div><div><span>Next hearing</span><strong>@(item.NextHearingDate?.ToString("dd MMM yyyy, h:mm tt") ?? "Not scheduled")</strong></div><div><span>Created</span><strong>@item.CreatedAt.ToString("dd MMM yyyy")</strong></div></div><div class="d-flex gap-2 mt-3"><a asp-action="Details" asp-route-id="@item.CaseId" class="btn btn-primary flex-fill">Details</a><a asp-controller="Document" asp-action="Index" asp-route-caseId="@item.CaseId" class="btn btn-outline-secondary flex-fill">Documents</a></div></article></div>
    }
    </div>
}
