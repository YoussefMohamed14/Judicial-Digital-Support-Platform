@model JDSP.ViewModels.Cases.MockPaymentViewModel
@{
    Layout = "_LawyerLayout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = Model.IsEdit ? (ar ? "تعديل طلب دفع" : "Edit payment request") : (ar ? "طلب دفع" : "Payment request");
}

<a asp-controller="Cases" asp-action="LawyerDetails" asp-route-id="@Model.CaseId" class="back-link">@(ar ? "→ الرجوع إلى القضية" : "← Back to case")</a>
<div class="page-head mt-3">
    <span class="eyebrow">@(ar ? "الدفع" : "Payment")</span>
    <h1>@(Model.IsEdit ? (ar ? "تعديل طلب الدفع المعلق" : "Edit pending payment request") : (ar ? "إرسال طلب دفع للعميل" : "Send payment request to client"))</h1>
    <p>@(Model.IsEdit ? (ar ? "سيتم تحديث نفس بطاقة الدفع الموجودة في رسائل العميل، ولن يتم إرسال بطاقة جديدة." : "This updates the same payment card in the client DM instead of sending another one.") : (ar ? "املأ بيانات الدفع، ثم اضغط إرسال ليصل الطلب إلى رسائل العميل." : "Fill the payment request, then submit it to the client DM."))</p>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <section class="card-panel request-form-card">
            <form asp-action="CreatePaymentRequest" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="CaseId" />
                <input type="hidden" asp-for="PaymentId" />
                <input type="hidden" asp-for="IsEdit" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="detail-grid mb-4">
                    <div><span>@(ar ? "القضية" : "Case")</span><strong>@Model.CaseName</strong></div>
                    <div><span>@(ar ? "العميل" : "Client")</span><strong>@Model.ClientName</strong></div>
                </div>

                <div class="mb-3">
                    <label asp-for="Amount" class="form-label fw-semibold">@(ar ? "المبلغ" : "Amount")</label>
                    <input asp-for="Amount" class="form-control" type="number" min="1" step="0.01" />
                    <span asp-validation-for="Amount" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="BillingType" class="form-label fw-semibold">@(ar ? "نوع الدفع" : "Payment type")</label>
                    <select asp-for="BillingType" class="form-select">
                        <option value="OneTime">@(ar ? "مرة واحدة / لكل قضية" : "One time / per case")</option>
                        <option value="Monthly">@(ar ? "شهري" : "Per month")</option>
                        <option value="Hourly">@(ar ? "بالساعة" : "Per hour")</option>
                    </select>
                    <span asp-validation-for="BillingType" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Note" class="form-label fw-semibold">@(ar ? "ملاحظة للعميل" : "Note to client")</label>
                    <textarea asp-for="Note" class="form-control" rows="4" maxlength="1000" placeholder="@(ar ? "مثال: دفعة أتعاب القضية" : "Example: Case service payment")"></textarea>
                    <span asp-validation-for="Note" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary px-4">@(Model.IsEdit ? (ar ? "حفظ التعديل" : "Save changes") : (ar ? "إرسال" : "Submit"))</button>
            </form>
        </section>
    </div>
    <div class="col-lg-4">
        <section class="card-panel">
            <div class="setting-title"><b>ⓘ</b><div><h2>@(ar ? "كيف يعمل؟" : "How it works")</h2><p>@(ar ? "يظهر الطلب في رسائل العميل مع أزرار الدفع أو الرفض بسبب." : "The request appears in the client DM with Pay or Decline with reason buttons.")</p></div></div>
            <div class="guideline-list">
                <div><b>1</b><span>@(ar ? "اختر نوع الدفع: مرة واحدة، شهري، أو بالساعة." : "Choose the payment type: one time, monthly, or hourly.")</span></div>
                <div><b>2</b><span>@(ar ? "بعد الدفع تصبح بطاقة الدفع خضراء في الرسائل." : "After payment succeeds, the payment card turns green in messages.")</span></div>
                <div><b>3</b><span>@(ar ? "هذه عملية دفع تجريبية ولا تحفظ بيانات البطاقة." : "This is a mock payment flow and card details are not stored.")</span></div>
            </div>
        </section>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
