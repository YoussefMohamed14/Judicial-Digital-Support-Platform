@model JDSP.ViewModels.Cases.ClientCaseDetailsViewModel
@{ Layout = "_ClientLayout"; ViewData["Title"] = "Case details"; }
<div class="page-head d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3"><div><a asp-action="MyCases" class="back-link">← Back to cases</a><h1 class="mt-2">@Model.CaseName</h1><p>Case #@Model.CaseId · Created @Model.CreatedAt.ToString("dd MMM yyyy")</p></div><span class="status large @Model.Status.ToLower().Replace(" ", "-")">@Model.Status</span></div>
<div class="row g-4"><div class="col-lg-8"><section class="card-panel mb-4"><div class="panel-head"><div><h2>Case information</h2><p>The submitted case details.</p></div></div><div class="detail-grid"><div><span>Case type</span><strong>@Model.CaseType</strong></div><div><span>Created date</span><strong>@Model.CreatedAt.ToString("dd MMM yyyy, h:mm tt")</strong></div></div><div class="description mt-3"><span>Description</span><p>@Model.Description</p></div></section><section class="card-panel"><div class="panel-head"><div><h2>Documents</h2><p>Review files connected to this official case.</p></div><a asp-controller="Document" asp-action="Index" class="btn btn-outline-secondary">Open documents</a></div></section></div>
<div class="col-lg-4"><section class="card-panel mb-4"><div class="panel-head"><div><h2>Lawyer assignment</h2><p>Latest request status.</p></div></div><div class="info-row"><span>Lawyer</span><strong>@(Model.AssignedLawyerName ?? "Not assigned")</strong></div><div class="info-row"><span>Status</span><strong>@(Model.LawyerRequestStatus ?? "No request")</strong></div>@if(Model.AssignedLawyerName == null){<a asp-controller="Lawyers" asp-action="Index" class="btn btn-primary w-100 mt-3">Find a lawyer</a>}</section><section class="card-panel"><div class="panel-head"><div><h2>Next hearing</h2><p>Nearest scheduled hearing.</p></div></div>@if(Model.NextHearingDate.HasValue){<div class="hearing"><b>@Model.NextHearingDate.Value.Day</b><div><strong>@Model.NextHearingDate.Value.ToString("MMMM yyyy")</strong><small>@Model.NextHearingDate.Value.ToString("dddd, h:mm tt")</small></div></div><div class="info-row"><span>Type</span><strong>@Model.NextHearingType</strong></div><div class="info-row"><span>Location</span><strong>@(Model.NextHearingLocation ?? "To be confirmed")</strong></div>}else{<div class="empty compact"><b>◷</b><p>No upcoming hearing.</p></div>}</section></div></div>
