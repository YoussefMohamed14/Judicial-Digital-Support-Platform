@model ErrorViewModel
@{
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    Layout = User.Identity?.IsAuthenticated == true
        ? (User.IsInRole("Admin") || User.IsInRole("CourtEmployee") ? "_CourtLayout" : (User.IsInRole("Lawyer") ? "_LawyerLayout" : "_ClientLayout"))
        : "_PublicLayout";
    ViewData["Title"] = ar ? "حدث خطأ" : "Error";
}

<section class="card-panel text-center mx-auto" style="max-width:720px">
    <img src="~/images/jdsp-court-system.png" alt="JDSP" style="width:100px;height:100px;object-fit:contain" class="mb-3" />
    <span class="eyebrow">JDSP</span>
    <h1 class="mt-2">@(ar ? "حدث خطأ" : "Something went wrong")</h1>
    <p class="text-secondary">@(ar ? "حدث خطأ أثناء معالجة طلبك." : "An error occurred while processing your request.")</p>
    @if (Model?.ShowRequestId == true) {
        <p><strong>@(ar ? "رقم الطلب:" : "Request ID:")</strong> <code>@Model.RequestId</code></p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">@(ar ? "الرئيسية" : "Home")</a>
</section>
