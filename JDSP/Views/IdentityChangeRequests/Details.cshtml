@using System.Globalization
@using JDSP.Helpers
@model JDSP.ViewModels.IdentityChangeRequests.IdentityChangeRequestDetailsViewModel
@{
    Layout = "_CourtLayout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = ar ? "تفاصيل طلب تعديل الهوية" : "Identity request details";
    var pending = Model.Status == VerificationStatus.Pending;
}

<div class="page-head d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div>
        <span class="eyebrow">@(ar ? "مراجعة الهوية" : "Identity review")</span>
        <h1>@Model.RequestedByName</h1>
        <p>@(ar ? "قارن البيانات الحالية بالمطلوبة قبل الموافقة." : "Compare current values with requested values before approval.")</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">@(ar ? "رجوع للطلبات" : "Back to requests")</a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <section class="card-panel h-100">
            <div class="panel-head"><div><h2>@(ar ? "البيانات المطلوبة" : "Requested changes")</h2><p>@(ar ? "التغيير لا يطبّق إلا بعد الموافقة." : "Changes apply only after approval.")</p></div><span class="status @(Model.Status.ToLowerInvariant())">@UiText.Status(Model.Status, ar)</span></div>
            <div class="identity-compare-grid">
                <div class="compare-card"><span>@(ar ? "الاسم الحالي" : "Current name")</span><strong>@Model.CurrentFullName</strong></div>
                <div class="compare-card requested"><span>@(ar ? "الاسم المطلوب" : "Requested name")</span><strong>@Model.RequestedFullName</strong></div>
                <div class="compare-card"><span>@(ar ? "الهاتف الحالي" : "Current phone")</span><strong>@(string.IsNullOrWhiteSpace(Model.CurrentPhoneNumber) ? (ar ? "غير متوفر" : "Not provided") : Model.CurrentPhoneNumber)</strong></div>
                <div class="compare-card requested"><span>@(ar ? "الهاتف المطلوب" : "Requested phone")</span><strong>@(string.IsNullOrWhiteSpace(Model.RequestedPhoneNumber) ? (ar ? "غير متوفر" : "Not provided") : Model.RequestedPhoneNumber)</strong></div>
                <div class="compare-card"><span>@(ar ? "الرقم القومي الحالي" : "Current national number")</span><strong>@Model.CurrentNationalNumber</strong></div>
                <div class="compare-card requested"><span>@(ar ? "الرقم القومي المطلوب" : "Requested national number")</span><strong>@Model.RequestedNationalNumber</strong></div>
            </div>
            <div class="detail-grid mt-4">
                <div><span>@(ar ? "البريد" : "Email")</span><strong>@Model.Email</strong></div>
                <div><span>@(ar ? "تاريخ الطلب" : "Requested")</span><strong>@Model.RequestedAt.ToString("yyyy-MM-dd HH:mm")</strong></div>
                <div><span>@(ar ? "تاريخ المراجعة" : "Reviewed")</span><strong>@(Model.ReviewedAt?.ToString("yyyy-MM-dd HH:mm") ?? (ar ? "لم تتم" : "Not reviewed"))</strong></div>
                <div><span>@(ar ? "المستند" : "Document")</span><strong>@Model.LegalIdFileName</strong></div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.RejectionReason)) {
                <div class="alert alert-danger mt-4"><strong>@(ar ? "سبب الرفض:" : "Rejection reason:")</strong> @Model.RejectionReason</div>
            }
        </section>
    </div>
    <div class="col-lg-4">
        <section class="card-panel mb-4">
            <div class="setting-title"><b>☷</b><div><h2>@(ar ? "المرفق" : "Attachment")</h2><p>@(ar ? "بطاقة الهوية القانونية المرفقة." : "Attached legal ID reference.")</p></div></div>
            <a asp-action="Download" asp-route-id="@Model.RequestId" class="btn btn-outline-primary w-100">@(ar ? "تحميل بطاقة الهوية" : "Download legal ID")</a>
        </section>
        @if (pending) {
            <section class="card-panel">
                <h2 class="h5 fw-bold mb-3">@(ar ? "قرار المراجعة" : "Review decision")</h2>
                <form asp-action="Approve" asp-route-id="@Model.RequestId" method="post" class="d-grid gap-2 mb-2">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-success">@(ar ? "موافقة وتطبيق التعديل" : "Approve and apply changes")</button>
                </form>
                <a asp-action="Reject" asp-route-id="@Model.RequestId" class="btn btn-outline-danger w-100">@(ar ? "رفض مع سبب" : "Reject with reason")</a>
            </section>
        }
    </div>
</div>
