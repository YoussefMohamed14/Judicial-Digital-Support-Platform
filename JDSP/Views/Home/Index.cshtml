@using System.Globalization
@{
    Layout = "_PublicLayout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = ar ? "دعم قضائي أسهل" : "Judicial support made simpler";
}
<section class="hero">
<div class="container py-5"><div class="row align-items-center g-5 py-lg-5">
<div class="col-lg-6">
    <span class="eyebrow">@(ar ? "دعم قانوني رقمي آمن" : "Secure digital legal support")</span>
    <h1 class="display-4 fw-bold mt-3">@(ar ? "أدِر رحلتك القانونية بوضوح وثقة." : "Manage your legal journey with clarity and confidence.")</h1>
    <p class="lead text-secondary mt-4">@(ar ? "تربط JDSP العملاء بمحامين مؤهلين، وتنظم معلومات القضايا، وتُظهر مواعيد الجلسات القادمة بوضوح." : "JDSP connects clients with qualified lawyers, organizes case information, and keeps upcoming hearings visible.")</p>
    <div class="d-flex flex-wrap gap-3 mt-4"><a class="btn btn-primary btn-lg px-4" asp-controller="Account" asp-action="Register">@(ar ? "إنشاء حساب" : "Create your account")</a><a class="btn btn-outline-primary btn-lg px-4" asp-controller="Account" asp-action="Login">@(ar ? "تسجيل الدخول" : "Sign in")</a></div>
    <div class="trust-row mt-5"><div><strong>@(ar ? "آمن" : "Secure")</strong><small>@(ar ? "وصول حسب الهوية" : "Identity-based access")</small></div><div><strong>@(ar ? "منظم" : "Organized")</strong><small>@(ar ? "قضايا وجلسات" : "Cases and hearings")</small></div><div><strong>@(ar ? "متصل" : "Connected")</strong><small>@(ar ? "عملاء ومحامون" : "Clients and lawyers")</small></div></div>
</div>
<div class="col-lg-6"><div class="hero-card"><div class="d-flex justify-content-between"><div><small class="text-secondary">@(ar ? "مساحة العميل" : "Client workspace")</small><h4>@(ar ? "نظرة عامة على ملفك القانوني" : "Your legal overview")</h4></div><span class="pill">@(ar ? "محمي" : "Protected")</span></div><div class="row g-3 my-3"><div class="col-6"><div class="mini-stat"><small>@(ar ? "القضايا النشطة" : "Active cases")</small><strong>03</strong></div></div><div class="col-6"><div class="mini-stat"><small>@(ar ? "الجلسة القادمة" : "Next hearing")</small><strong>18 Jul</strong></div></div></div><div class="preview">⚖ <div><strong>@(ar ? "نزاع عقاري" : "Property dispute")</strong><small>@(ar ? "تم تعيين محامٍ · تم تحديد جلسة" : "Lawyer assigned · Hearing scheduled")</small></div></div><div class="preview">✓ <div><strong>@(ar ? "المستندات جاهزة" : "Documents ready")</strong><small>@(ar ? "تم تنظيم أحدث ملفاتك" : "Your latest files are organized")</small></div></div></div></div>
</div></div>
</section>
<section id="features" class="section"><div class="container py-5"><div class="text-center section-title"><span class="eyebrow">@(ar ? "كل شيء في مكان واحد" : "Everything in one place")</span><h2 class="fw-bold mt-2">@(ar ? "طريقة أوضح للتعامل مع القضايا القانونية" : "A clearer way to handle legal cases")</h2></div><div class="row g-4 mt-3"><div class="col-md-4"><div class="feature"><b>▣</b><h4>@(ar ? "إدارة القضايا" : "Case management")</h4><p>@(ar ? "ينشئ موظفو المحكمة القضايا الرسمية بينما يراجع العملاء والمحامون الحالة والتفاصيل بأمان." : "Court Employees create official cases while clients and lawyers securely review status and details.")</p></div></div><div class="col-md-4"><div class="feature"><b>⚖</b><h4>@(ar ? "ابحث عن المحامي المناسب" : "Find the right lawyer")</h4><p>@(ar ? "تصفح الملفات المهنية، تابع المحامين، وأرسل طلبات مرتبطة بحالتك." : "Browse profiles, follow lawyers, and send case-specific requests.")</p></div></div><div class="col-md-4"><div class="feature"><b>◷</b><h4>@(ar ? "متابعة الجلسات" : "Hearing awareness")</h4><p>@(ar ? "اعرض المواعيد والمواقع القادمة من لوحة تحكم العميل." : "See upcoming dates and locations from your client dashboard.")</p></div></div></div></div></section>
<section id="steps" class="section soft"><div class="container py-5"><div class="row g-5 align-items-center"><div class="col-lg-5"><span class="eyebrow">@(ar ? "كيف تعمل" : "How it works")</span><h2 class="fw-bold mt-2">@(ar ? "ابدأ في ثلاث خطوات بسيطة." : "Start in three simple steps.")</h2><p class="text-secondary">@(ar ? "يحافظ حسابك على ربط هويتك وملفك الشخصي وقضاياك." : "Your account keeps your identity, profile, and cases connected.")</p></div><div class="col-lg-7"><div class="steps"><div><span>1</span><p><strong>@(ar ? "أنشئ حسابك" : "Create your account")</strong><br/>@(ar ? "سجل كعميل أو محامٍ." : "Register as a client or lawyer.")</p></div><div><span>2</span><p><strong>@(ar ? "أكمل ملفك الشخصي" : "Complete your profile")</strong><br/>@(ar ? "أضف صورة ونبذة قصيرة." : "Add a photo and short bio.")</p></div><div><span>3</span><p><strong>@(ar ? "أدِر العمل القانوني" : "Manage legal work")</strong><br/>@(ar ? "يرسل العملاء الطلبات، يرد المحامون، وينشئ موظفو المحكمة القضايا الرسمية." : "Clients send requests, lawyers respond, and Court Employees create official cases.")</p></div></div></div></div></div></section>
