@{ Layout = "_PublicLayout"; ViewData["Title"] = "Judicial support made simpler"; }
<section class="hero">
<div class="container py-5"><div class="row align-items-center g-5 py-lg-5">
<div class="col-lg-6">
    <span class="eyebrow">Secure digital legal support</span>
    <h1 class="display-4 fw-bold mt-3">Manage your legal journey with clarity and confidence.</h1>
    <p class="lead text-secondary mt-4">JDSP connects clients with qualified lawyers, organizes case information, and keeps upcoming hearings visible.</p>
    <div class="d-flex flex-wrap gap-3 mt-4"><a class="btn btn-primary btn-lg px-4" asp-controller="Account" asp-action="Register">Create your account</a><a class="btn btn-outline-primary btn-lg px-4" asp-controller="Account" asp-action="Login">Sign in</a></div>
    <div class="trust-row mt-5"><div><strong>Secure</strong><small>Identity-based access</small></div><div><strong>Organized</strong><small>Cases and hearings</small></div><div><strong>Connected</strong><small>Clients and lawyers</small></div></div>
</div>
<div class="col-lg-6"><div class="hero-card"><div class="d-flex justify-content-between"><div><small class="text-secondary">Client workspace</small><h4>Your legal overview</h4></div><span class="pill">Protected</span></div><div class="row g-3 my-3"><div class="col-6"><div class="mini-stat"><small>Active cases</small><strong>03</strong></div></div><div class="col-6"><div class="mini-stat"><small>Next hearing</small><strong>18 Jul</strong></div></div></div><div class="preview">⚖ <div><strong>Property dispute</strong><small>Lawyer assigned · Hearing scheduled</small></div></div><div class="preview">✓ <div><strong>Documents ready</strong><small>Your latest files are organized</small></div></div></div></div>
</div></div>
</section>
<section id="features" class="section"><div class="container py-5"><div class="text-center section-title"><span class="eyebrow">Everything in one place</span><h2 class="fw-bold mt-2">A clearer way to handle legal cases</h2></div><div class="row g-4 mt-3"><div class="col-md-4"><div class="feature"><b>▣</b><h4>Case management</h4><p>Court Employees create official cases while clients and lawyers securely review status and details.</p></div></div><div class="col-md-4"><div class="feature"><b>⚖</b><h4>Find the right lawyer</h4><p>Browse profiles, follow lawyers, and send case-specific requests.</p></div></div><div class="col-md-4"><div class="feature"><b>◷</b><h4>Hearing awareness</h4><p>See upcoming dates and locations from your client dashboard.</p></div></div></div></div></section>
<section id="steps" class="section soft"><div class="container py-5"><div class="row g-5 align-items-center"><div class="col-lg-5"><span class="eyebrow">How it works</span><h2 class="fw-bold mt-2">Start in three simple steps.</h2><p class="text-secondary">Your account keeps your identity, profile, and cases connected.</p></div><div class="col-lg-7"><div class="steps"><div><span>1</span><p><strong>Create your account</strong><br/>Register as a client or lawyer.</p></div><div><span>2</span><p><strong>Complete your profile</strong><br/>Add a photo and short bio.</p></div><div><span>3</span><p><strong>Manage legal work</strong><br/>Clients send requests, lawyers respond, and Court Employees create official cases.</p></div></div></div></div></div></section>
