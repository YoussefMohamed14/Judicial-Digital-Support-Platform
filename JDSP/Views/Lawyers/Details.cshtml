@model JDSP.ViewModels.Lawyers.LawyerListItemViewModel
@{
    Layout = User.IsInRole("Client") ? "_ClientLayout" : User.IsInRole("Lawyer") ? "_LawyerLayout" : "_Layout";
    ViewData["Title"] = Model.FullName;
    var initials = string.Join("", Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpperInvariant();
    var isLawyer = User.IsInRole("Lawyer");
}

@if (User.IsInRole("Client")) {
    <a asp-action="Index" class="back-link">← Back to lawyers</a>
}
else if (isLawyer) {
    <a asp-action="EditProfile" class="back-link">← Back to professional profile</a>
}

<div class="row g-4 mt-2">
    <div class="col-lg-4">
        <section class="card-panel profile-summary text-center">
            @if (!string.IsNullOrWhiteSpace(Model.PhotoPath)) { <img src="@Model.PhotoPath" class="profile-avatar" alt="@Model.FullName" /> }
            else { <div class="profile-avatar avatar-fallback">@initials</div> }
            <h2>@Model.FullName</h2><span class="role-pill">@Model.Specialization</span>
            <p class="text-secondary mt-3">@Model.YearsOfExperience years of experience</p>
            <span class="status @(Model.IsAvailable ? "open" : "closed")">@(Model.IsAvailable ? "Available" : "Not available")</span>
        </section>
    </div>
    <div class="col-lg-8">
        <section class="card-panel mb-4">
            <div class="panel-head">
                <div>
                    <h2>Professional profile</h2>
                    <p>@(isLawyer ? "This is how clients see your professional profile." : "Review the lawyer's experience before sending a request.")</p>
                </div>
                @if (isLawyer) {
                    <a asp-action="EditProfile" class="btn btn-sm btn-outline-primary">Edit profile</a>
                }
            </div>
            <div class="detail-grid">
                <div><span>Email</span><strong>@Model.Email</strong></div>
                <div><span>Specialization</span><strong>@Model.Specialization</strong></div>
                <div><span>Experience</span><strong>@Model.YearsOfExperience years</strong></div>
                <div><span>Consultation price</span><strong>@Model.ConsultationPrice.ToString("N2")</strong></div>
            </div>
            <div class="description mt-3"><span>Bio</span><p>@ViewBag.Bio</p></div>
        </section>
        @if (User.IsInRole("Client")) {
            <section class="card-panel">
                <div class="panel-head"><div><h2>Work with this lawyer</h2><p>Upload the case file and send a brief directly to the lawyer.</p></div></div>
                <div class="d-flex flex-wrap gap-2">
                    @if (Model.IsAvailable) { <a asp-controller="ServiceRequests" asp-action="SendToLawyer" asp-route-lawyerProfileId="@Model.LawyerProfileId" class="btn btn-primary">Send case request</a> }
                    else { <button class="btn btn-secondary" disabled>Currently unavailable</button> }
                    @if (Model.IsFollowed) {
                        <form asp-action="Unfollow" method="post">@Html.AntiForgeryToken()<input type="hidden" name="lawyerProfileId" value="@Model.LawyerProfileId" /><button type="submit" class="btn btn-outline-warning">Unfollow</button></form>
                    }
                    else {
                        <form asp-action="Follow" method="post">@Html.AntiForgeryToken()<input type="hidden" name="lawyerProfileId" value="@Model.LawyerProfileId" /><button type="submit" class="btn btn-outline-success">Follow</button></form>
                    }
                    <a asp-controller="Messages" asp-action="Index" class="btn btn-outline-secondary">Message</a>
                </div>
            </section>
        }
    </div>
</div>
