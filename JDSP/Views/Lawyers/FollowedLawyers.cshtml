@model List<JDSP.ViewModels.Lawyers.LawyerListItemViewModel>

<h2>Followed Lawyers</h2>

@if (!Model.Any()) {
    <div class="alert alert-info">You are not following any lawyers yet.</div>
}
else {
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Specialization</th>
                <th>Experience</th>
                <th>Price</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var lawyer in Model) {
                <tr>
                    <td>@lawyer.FullName</td>
                    <td>@lawyer.Specialization</td>
                    <td>@lawyer.YearsOfExperience years</td>
                    <td>@lawyer.ConsultationPrice</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@lawyer.LawyerProfileId" class="btn btn-sm btn-primary">
                            Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}