@model JDSP.ViewModels.Lawyers.LawyerSearchViewModel
@{
    Layout = User.IsInRole("Client") ? "_ClientLayout" : User.IsInRole("Lawyer") ? "_LawyerLayout" : "_Layout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = ar ? "البحث عن محامين" : "Find lawyers";
}

<div class="page-head"><span class="eyebrow">@(ar ? "دليل المحامين" : "Lawyer directory")</span><h1>@(ar ? "ابحث عن محامٍ" : "Find a lawyer")</h1><p>@(ar ? "تصفح الملفات المهنية، تابع المحامين، أو أرسل طلباً مباشراً مع النبذة وملف القضية." : "Browse professional profiles, follow lawyers, or send a direct request with your brief and case file.")</p></div>

<section class="card-panel mb-4">
    <form method="get" asp-action="Index">
        <div class="row g-3">
            <div class="col-md-5"><label class="form-label fw-semibold">@(ar ? "الاسم أو الكلمة المفتاحية" : "Name or keyword")</label><input name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="@(ar ? "ابحث بالاسم أو التخصص" : "Search by name or specialization")" /></div>
            <div class="col-md-5"><label class="form-label fw-semibold">@(ar ? "التخصص" : "Specialization")</label><select name="specialization" class="form-select"><option value="">@(ar ? "كل التخصصات" : "All specializations")</option>@foreach (var item in UiText.SpecializationOptions) {<option value="@item" selected="@(Model.Specialization == item)">@UiText.Specialization(item, ar)</option>}</select></div>
            <div class="col-md-2 d-grid align-self-end"><button type="submit" class="btn btn-primary">@(ar ? "بحث" : "Search")</button></div>
        </div>
    </form>
</section>

@if (!Model.Lawyers.Any()) {
    <section class="card-panel empty"><b>⚖</b><h3>@(ar ? "لم يتم العثور على محامين" : "No lawyers found")</h3><p>@(ar ? "جرّب اسماً أو تخصصاً مختلفاً." : "Try a different name or specialization.")</p></section>
}
else {
    <div class="row g-4">
        @foreach (var lawyer in Model.Lawyers) {
            var initials = string.Join("", lawyer.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpperInvariant();
            <div class="col-md-6 col-xl-4">
                <article class="card-panel lawyer-card h-100">
                    <div class="lawyer-card-head">
                        @if (!string.IsNullOrWhiteSpace(lawyer.PhotoPath)) { <img src="@lawyer.PhotoPath" class="lawyer-avatar" alt="@lawyer.FullName" /> }
                        else { <div class="lawyer-avatar avatar-fallback">@initials</div> }
                        <div><h2>@lawyer.FullName</h2><span class="case-type">@UiText.Specialization(lawyer.Specialization, ar)</span></div>
                    </div>
                    <div class="detail-grid compact-grid mt-3"><div><span>@(ar ? "الخبرة" : "Experience")</span><strong>@UiText.YearsShort(lawyer.YearsOfExperience, ar)</strong></div><div><span>@(ar ? "السعر" : "Price")</span><strong>@UiText.Price(lawyer.ConsultationPrice, lawyer.ConsultationPriceUnit, ar)</strong></div></div>
                    <div class="d-flex justify-content-between align-items-center mt-3"><span class="status @(lawyer.IsAvailable ? "open" : "closed")">@UiText.Availability(lawyer.IsAvailable, ar)</span>@if (lawyer.IsFollowed) { <span class="small text-secondary">★ @(ar ? "متابَع" : "Followed")</span> }</div>
                    <a asp-action="Details" asp-route-id="@lawyer.LawyerProfileId" class="btn btn-outline-primary mt-3">@(ar ? "عرض الملف" : "View profile")</a>
                </article>
            </div>
        }
    </div>
}
