@model JDSP.ViewModels.Lawyers.LawyerProfileViewModel
@{
    Layout = "_LawyerLayout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = ar ? "إنشاء الملف المهني" : "Create professional profile";
}

<div class="page-head"><span class="eyebrow">@(ar ? "ملف المحامي" : "Lawyer profile")</span><h1>@(ar ? "أكمل ملفك المهني" : "Complete your professional profile")</h1><p>@(ar ? "أضف الخبرة القانونية التي يحتاجها العملاء قبل اختيارك والتواصل معك." : "Add the legal experience clients need before they can choose and contact you.")</p></div>
<div class="row justify-content-center"><div class="col-xl-8"><section class="card-panel"><form asp-action="CreateProfile" method="post">@Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary-valid"></div><div class="mb-3"><label asp-for="Specialization" class="form-label fw-semibold">@(ar ? "التخصص" : "Specialization")</label><input asp-for="Specialization" class="form-control" placeholder="@(ar ? "مثال: القانون التجاري" : "e.g. Commercial law")"/><span asp-validation-for="Specialization" class="text-danger small"></span></div><div class="mb-3"><label asp-for="Bio" class="form-label fw-semibold">@(ar ? "النبذة المهنية" : "Professional bio")</label><textarea asp-for="Bio" class="form-control" rows="7" placeholder="@(ar ? "اكتب مؤهلاتك وخبراتك والخدمات التي تقدمها..." : "Describe your qualifications, experience, and services...")"></textarea><span asp-validation-for="Bio" class="text-danger small"></span></div><div class="row g-3"><div class="col-md-6"><label asp-for="YearsOfExperience" class="form-label fw-semibold">@(ar ? "سنوات الخبرة" : "Years of experience")</label><input asp-for="YearsOfExperience" class="form-control"/><span asp-validation-for="YearsOfExperience" class="text-danger small"></span></div><div class="col-md-6"><label asp-for="ConsultationPrice" class="form-label fw-semibold">@(ar ? "سعر الاستشارة" : "Consultation price")</label><input asp-for="ConsultationPrice" class="form-control"/><span asp-validation-for="ConsultationPrice" class="text-danger small"></span></div></div><div class="form-check form-switch my-4"><input asp-for="IsAvailable" class="form-check-input"/><label asp-for="IsAvailable" class="form-check-label fw-semibold">@(ar ? "متاح لاستقبال طلبات جديدة" : "Available to receive new requests")</label></div><button type="submit" class="btn btn-primary px-4">@(ar ? "إنشاء الملف المهني" : "Create professional profile")</button></form></section></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
