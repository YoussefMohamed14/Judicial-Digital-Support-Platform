@model JDSP.ViewModels.Lawyers.LawyerProfileViewModel
@{ Layout = "_LawyerLayout"; ViewData["Title"] = "Create professional profile"; }

<div class="page-head"><span class="eyebrow">Lawyer profile</span><h1>Complete your professional profile</h1><p>Add the legal experience clients need before they can choose and contact you.</p></div>
<div class="row justify-content-center"><div class="col-xl-8"><section class="card-panel"><form asp-action="CreateProfile" method="post">@Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary-valid"></div><div class="mb-3"><label asp-for="Specialization" class="form-label fw-semibold"></label><input asp-for="Specialization" class="form-control" placeholder="e.g. Commercial law"/><span asp-validation-for="Specialization" class="text-danger small"></span></div><div class="mb-3"><label asp-for="Bio" class="form-label fw-semibold"></label><textarea asp-for="Bio" class="form-control" rows="7" placeholder="Describe your qualifications, experience, and services..."></textarea><span asp-validation-for="Bio" class="text-danger small"></span></div><div class="row g-3"><div class="col-md-6"><label asp-for="YearsOfExperience" class="form-label fw-semibold"></label><input asp-for="YearsOfExperience" class="form-control"/><span asp-validation-for="YearsOfExperience" class="text-danger small"></span></div><div class="col-md-6"><label asp-for="ConsultationPrice" class="form-label fw-semibold"></label><input asp-for="ConsultationPrice" class="form-control"/><span asp-validation-for="ConsultationPrice" class="text-danger small"></span></div></div><div class="form-check form-switch my-4"><input asp-for="IsAvailable" class="form-check-input"/><label asp-for="IsAvailable" class="form-check-label fw-semibold">Available to receive new requests</label></div><button type="submit" class="btn btn-primary px-4">Create professional profile</button></form></section></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
