@model IEnumerable<JDSP.ViewModel.MyRequestStatusViewModel>
@{
    Layout = User.IsInRole("Client") ? "_ClientLayout" : "_Layout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = ar ? "طلباتي" : "My Requests";
}

<div class="container mt-4">
    <h2 class="mb-1">@(ar ? "طلباتي" : "My Requests")</h2>
    <p class="text-muted mb-4">@(ar ? "تابع حالة طلبات المحامين." : "Track the status of your lawyer requests.")</p>

    @if (!Model.Any())
    {
        <div class="alert alert-info">@(ar ? "لم ترسل أي طلبات بعد." : "You have not sent any requests yet.")</div>
    }
    else
    {
        <table class="table table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>@(ar ? "القضية" : "Case")</th>
                    <th>@(ar ? "المحامي" : "Lawyer")</th>
                    <th>@(ar ? "الحالة" : "Status")</th>
                    <th>@(ar ? "السعر المقترح" : "Proposed Price")</th>
                    <th>@(ar ? "الإجراء" : "Action")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var req in Model)
                {
                    <tr>
                        <td>@req.CaseName</td>
                        <td>@req.LawyerName</td>
                        <td>
                            @{
                                var badge = req.Status switch
                                {
                                    "Pending" => "warning",
                                    "Accepted" => "success",
                                    "Rejected" => "danger",
                                    "Price Proposed" => "info",
                                    "OfferAccepted" => "primary",
                                    _ => "secondary"
                                };
                            }
                            <span class="badge bg-@badge">@UiText.Status(req.Status, ar)</span>
                        </td>
                        <td>@(req.ProposedPrice.HasValue ? req.ProposedPrice.Value.ToString("C") : "—")</td>
                        <td>
                            @if (req.Status == "Price Proposed")
                            {
                                <a asp-action="OfferDetails" asp-route-caseLawyerId="@req.CaseLawyerId" class="btn btn-primary btn-sm">@(ar ? "عرض العرض ←" : "View Offer →")</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
