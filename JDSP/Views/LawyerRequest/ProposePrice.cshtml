@model JDSP.ViewModel.ProposePriceViewModel
@{
    Layout = "_LawyerLayout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = ar ? "اقتراح سعر" : "Propose Price";
}

<div class="container mt-4" style="max-width:520px">
    <h2 class="mb-1">@(ar ? "اقتراح سعر" : "Propose a Price")</h2>
    <p class="text-muted mb-4">@(ar ? "حدد أتعابك للتعامل مع هذه القضية." : "Set your fee for handling this case.")</p>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="mb-2">
                <span class="text-muted small">@(ar ? "القضية" : "Case")</span>
                <p class="fw-semibold mb-0">@Model.CaseName</p>
            </div>
            <hr />
            <div>
                <span class="text-muted small">@(ar ? "العميل" : "Client")</span>
                <p class="fw-semibold mb-0">@Model.ClientName</p>
            </div>
        </div>
    </div>

    <form asp-action="ProposePrice" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CaseLawyerId" />
        <input type="hidden" asp-for="CaseName" />
        <input type="hidden" asp-for="ClientName" />

        <div class="mb-3">
            <label asp-for="ProposedPrice" class="form-label fw-semibold">@(ar ? "السعر المقترح" : "Proposed Price")</label>
            <div class="input-group">
                <span class="input-group-text">EGP</span>
                <input asp-for="ProposedPrice" class="form-control" type="number" min="1" step="0.01" placeholder="@(ar ? "مثال: 5000" : "e.g. 5000")" />
            </div>
            <span asp-validation-for="ProposedPrice" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">@(ar ? "إرسال السعر ←" : "Submit Price →")</button>
            <a asp-action="IncomingRequests" class="btn btn-outline-secondary">@(ar ? "إلغاء" : "Cancel")</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
