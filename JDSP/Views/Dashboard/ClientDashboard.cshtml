@using System.Globalization
@model JDSP.ViewModels.Dashboard.ClientDashboardViewModel
@{
    Layout = "_ClientLayout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = ar ? "لوحة تحكم العميل" : "Client dashboard";
}

<div class="page-head d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div>
        <span class="eyebrow">@(ar ? "مساحة العميل" : "Client workspace")</span>
        <h1>@(ar ? "مرحباً بعودتك،" : "Welcome back,") @Model.ClientName</h1>
        <p>@(ar ? "تابع القضايا التي أنشأتها المحكمة، تواصل مع المحامين، وأدِر طلباتك القانونية." : "Track court-created cases, contact lawyers, and manage your legal requests.")</p>
    </div>
    <a asp-controller="ServiceRequests" asp-action="CreatePublic" class="btn btn-primary px-4">@(ar ? "+ نشر طلب عام" : "+ Post a public request")</a>
</div>

<div class="row g-3 stats-row">
    <div class="col-sm-6 col-xl"><div class="stat"><span>▣</span><div><small>@(ar ? "إجمالي القضايا" : "Total cases")</small><strong>@Model.TotalCases</strong></div></div></div>
    <div class="col-sm-6 col-xl"><div class="stat"><span>●</span><div><small>@(ar ? "القضايا النشطة" : "Active cases")</small><strong>@Model.ActiveCases</strong></div></div></div>
    <div class="col-sm-6 col-xl"><div class="stat"><span>☆</span><div><small>@(ar ? "المحامون المتابعون" : "Followed lawyers")</small><strong>@Model.FollowedLawyers</strong></div></div></div>
    <div class="col-sm-6 col-xl"><div class="stat"><span>◎</span><div><small>@(ar ? "الطلبات العامة" : "Public requests")</small><strong>@Model.PublicRequests</strong></div></div></div>
    <div class="col-sm-6 col-xl"><div class="stat"><span>⇄</span><div><small>@(ar ? "الطلبات المعلقة" : "Pending requests")</small><strong>@Model.PendingRequests</strong></div></div></div>
</div>

<div class="row g-4 mt-1">
    <div class="col-lg-8">
        <section class="card-panel h-100">
            <div class="panel-head">
                <div><h2>@(ar ? "أحدث القضايا" : "Recent cases")</h2><p>@(ar ? "القضايا الرسمية التي أنشأها موظف المحكمة لك." : "Official cases created for you by a Court Employee.")</p></div>
                <a asp-controller="Cases" asp-action="MyCases" class="btn btn-sm btn-outline-secondary">@(ar ? "عرض الكل" : "View all")</a>
            </div>
            @if (Model.RecentCases.Count == 0) {
                <div class="empty">
                    <b>▣</b>
                    <h3>@(ar ? "لا توجد قضايا رسمية بعد" : "No official cases yet")</h3>
                    <p>@(ar ? "يقوم موظف المحكمة بإنشاء القضية الرسمية وإسنادها إلى حسابك. يمكنك الآن التواصل مع محامٍ أو نشر طلب." : "A Court Employee creates the official case and assigns it to your account. You can still contact a lawyer or publish a request now.")</p>
                    <div class="d-flex justify-content-center flex-wrap gap-2">
                        <a asp-controller="Lawyers" asp-action="Index" class="btn btn-primary">@(ar ? "ابحث عن محامٍ" : "Find a lawyer")</a>
                        <a asp-controller="ServiceRequests" asp-action="CreatePublic" class="btn btn-outline-primary">@(ar ? "نشر طلب عام" : "Post public request")</a>
                    </div>
                </div>
            }
            else {
                <div class="table-responsive">
                    <table class="table align-middle clean-table">
                        <thead><tr><th>@(ar ? "القضية" : "Case")</th><th>@(ar ? "النوع" : "Type")</th><th>@(ar ? "الحالة" : "Status")</th><th>@(ar ? "تاريخ الإنشاء" : "Created")</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var item in Model.RecentCases) {
                            <tr>
                                <td class="fw-semibold">@item.CaseName</td>
                                <td>@item.CaseType</td>
                                <td><span class="status @item.Status.ToLower().Replace(" ", "-")">@UiText.Status(item.Status, ar)</span></td>
                                <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td><a asp-controller="Cases" asp-action="Details" asp-route-id="@item.CaseId" class="btn btn-sm btn-light">@(ar ? "التفاصيل" : "Details")</a></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
    <div class="col-lg-4">
        <section class="card-panel mb-4">
            <div class="panel-head"><div><h2>@(ar ? "الجلسة القادمة" : "Next hearing")</h2><p>@(ar ? "أقرب جلسة مجدولة لك." : "Your nearest scheduled hearing.")</p></div></div>
            @if (Model.NextHearingDate.HasValue) {
                <div class="hearing"><b>@Model.NextHearingDate.Value.Day</b><div><strong>@Model.NextHearingDate.Value.ToString("MMMM yyyy")</strong><small>@Model.NextHearingDate.Value.ToString("dddd, h:mm tt")</small></div></div>
                <div class="info-row"><span>@(ar ? "القضية" : "Case")</span><strong>@Model.NextHearingCaseName</strong></div>
                <div class="info-row"><span>@(ar ? "المكان" : "Location")</span><strong>@(Model.NextHearingLocation ?? (ar ? "لم يتم التأكيد بعد" : "To be confirmed"))</strong></div>
                <div class="hearing-countdown mt-3" data-hearing-start="@Model.NextHearingDate.Value.ToString("o")" data-hearing-end="@(Model.NextHearingEndDate?.ToString("o") ?? Model.NextHearingDate.Value.ToString("o"))"><span>@(ar ? "يبدأ بعد" : "Starts in")</span><strong>--</strong></div>
            }
            else { <div class="empty compact"><b>◷</b><p>@(ar ? "لا توجد جلسات قادمة." : "No upcoming hearing.")</p></div> }
        </section>
        <section class="card-panel">
            <div class="panel-head"><div><h2>@(ar ? "إجراءات سريعة" : "Quick actions")</h2><p>@(ar ? "ابدأ من الإجراء الذي تحتاجه." : "Start from the action you need.")</p></div></div>
            <div class="quick">
                <a asp-controller="Lawyers" asp-action="Index">⚖ <span><strong>@(ar ? "ابحث عن محامين" : "Find lawyers")</strong><small>@(ar ? "اختر محامياً، أرفق ملفك، وأرسل نبذة" : "Choose a lawyer, attach your file, and send a brief")</small></span></a>
                <a asp-controller="ServiceRequests" asp-action="CreatePublic">◎ <span><strong>@(ar ? "طلب عام" : "Public request")</strong><small>@(ar ? "دع المحامين المتاحين يرسلون عروضاً" : "Let available lawyers send proposals")</small></span></a>
                <a asp-controller="ServiceRequests" asp-action="MyRequests">⇄ <span><strong>@(ar ? "طلباتي" : "My requests")</strong><small>@(ar ? "راجع الطلبات المباشرة والعامة" : "Review direct and public requests")</small></span></a>
                <a asp-controller="Messages" asp-action="Index">✉ <span><strong>@(ar ? "الرسائل" : "Messages")</strong><small>@(ar ? "سيتم ربط منطق الرسائل لاحقاً" : "Messaging logic will be connected later")</small></span></a>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="~/js/hearing-countdown.js" asp-append-version="true"></script>
}
