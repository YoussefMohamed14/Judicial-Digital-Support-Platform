@model JDSP.ViewModels.Dashboard.LawyerDashboardViewModel
@{ Layout = "_LawyerLayout"; ViewData["Title"] = "Lawyer dashboard"; }

<div class="page-head d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div>
        <span class="eyebrow">Lawyer workspace</span>
        <h1>Welcome back, @Model.LawyerName</h1>
        <p>Review client requests, public opportunities, assigned cases, and your next hearing.</p>
    </div>
    <a asp-controller="ServiceRequests" asp-action="PublicRequests" class="btn btn-primary px-4">Browse public requests</a>
</div>

<div class="row g-3 stats-row">
    <div class="col-sm-6 col-xl-3"><div class="stat"><span>☆</span><div><small>Followers</small><strong>@Model.Followers</strong></div></div></div>
    <div class="col-sm-6 col-xl-3"><div class="stat"><span>◉</span><div><small>Current clients</small><strong>@Model.CurrentClients</strong></div></div></div>
    <div class="col-sm-6 col-xl-3"><div class="stat"><span>⇄</span><div><small>Pending requests</small><strong>@Model.PendingRequests</strong></div></div></div>
    <div class="col-sm-6 col-xl-3"><div class="stat"><span>▣</span><div><small>Assigned cases</small><strong>@Model.AssignedCases</strong></div></div></div>
</div>

<div class="row g-4 mt-1">
    <div class="col-lg-8">
        <section class="card-panel h-100">
            <div class="panel-head">
                <div><h2>Recent client requests</h2><p>Direct requests sent to your profile.</p></div>
                <a asp-controller="ServiceRequests" asp-action="Incoming" class="btn btn-sm btn-outline-secondary">View all</a>
            </div>
            @if (Model.RecentRequests.Count == 0) {
                <div class="empty"><b>⇄</b><h3>No direct requests yet</h3><p>Public requests are still available for you to browse and submit proposals.</p><a asp-controller="ServiceRequests" asp-action="PublicRequests" class="btn btn-primary">Browse public requests</a></div>
            }
            else {
                <div class="table-responsive">
                    <table class="table align-middle clean-table">
                        <thead><tr><th>Request</th><th>Client</th><th>Status</th><th>Received</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var item in Model.RecentRequests) {
                            <tr>
                                <td class="fw-semibold">@item.Subject</td>
                                <td>@item.ClientName</td>
                                <td><span class="status @item.Status.ToLower().Replace(" ", "-")">@item.Status</span></td>
                                <td>@item.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                                <td><a asp-controller="ServiceRequests" asp-action="Incoming" class="btn btn-sm btn-light">Open</a></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
    <div class="col-lg-4">
        <section class="card-panel mb-4">
            <div class="panel-head"><div><h2>Next hearing</h2><p>Nearest hearing for an assigned case.</p></div></div>
            @if (Model.NextHearingDate.HasValue) {
                <div class="hearing"><b>@Model.NextHearingDate.Value.Day</b><div><strong>@Model.NextHearingDate.Value.ToString("MMMM yyyy")</strong><small>@Model.NextHearingDate.Value.ToString("dddd, h:mm tt")</small></div></div>
                <div class="info-row"><span>Case</span><strong>@Model.NextHearingCaseName</strong></div>
                <div class="info-row"><span>Location</span><strong>@(Model.NextHearingLocation ?? "To be confirmed")</strong></div>
            }
            else { <div class="empty compact"><b>◷</b><p>No upcoming hearing.</p></div> }
        </section>
        <section class="card-panel">
            <div class="panel-head"><div><h2>Quick actions</h2><p>Common lawyer actions.</p></div></div>
            <div class="quick">
                <a asp-controller="ServiceRequests" asp-action="Incoming">⇄ <span><strong>Client requests</strong><small>Accept or reject direct requests</small></span></a>
                <a asp-controller="ServiceRequests" asp-action="PublicRequests">◎ <span><strong>Public requests</strong><small>Review files and send proposals</small></span></a>
                <a asp-controller="Cases" asp-action="AssignedCases">▣ <span><strong>Assigned cases</strong><small>View case status and hearing details</small></span></a>
                <a asp-controller="Messages" asp-action="Index">✉ <span><strong>Messages</strong><small>Conversation logic will be added later</small></span></a>
            </div>
        </section>
    </div>
</div>
