@model JDSP.ViewModels.Profile.ClientProfileViewModel
@{ Layout = User.IsInRole("Lawyer") ? "_LawyerLayout" : "_ClientLayout"; ViewData["Title"] = "Profile"; var initials = string.Join("", Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpperInvariant(); }
<div class="page-head"><span class="eyebrow">Account</span><h1>Profile</h1><p>Review verified identity information and update your public profile.</p></div>
<div class="row g-4"><div class="col-lg-4"><section class="card-panel profile-summary text-center">@if(!string.IsNullOrWhiteSpace(Model.PhotoPath)){<img src="@Model.PhotoPath" class="profile-avatar" alt="@Model.FullName"/>}else{<div class="profile-avatar avatar-fallback">@initials</div>}<h2>@Model.FullName</h2><span class="role-pill">@Model.Role</span><p class="text-secondary mt-3 mb-0">Member since @Model.CreatedAt.ToString("MMMM yyyy")</p>@if (User.IsInRole("Lawyer")) { <a asp-controller="Lawyers" asp-action="EditProfile" class="btn btn-outline-primary w-100 mt-3">Professional profile</a> }</section></div>
<div class="col-lg-8"><section class="card-panel mb-4"><div class="panel-head"><div><h2>Verified identity</h2><p>Legal details are view-only and require court approval to change.</p></div><span class="locked">🔒 Locked</span></div><div class="detail-grid"><div><span>Full name</span><strong>@Model.FullName</strong></div><div><span>Email</span><strong>@Model.Email</strong></div><div><span>Phone number</span><strong>@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "Not provided" : Model.PhoneNumber)</strong></div><div><span>National number</span><strong>@Model.NationalNumber</strong></div></div></section>
<section class="card-panel"><div class="panel-head"><div><h2>Editable profile</h2><p>You can freely update your photo and bio.</p></div></div><form asp-action="Update" method="post" enctype="multipart/form-data">@Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary-valid"></div><div class="mb-4"><label asp-for="NewPhoto" class="form-label fw-semibold">New profile photo</label><input asp-for="NewPhoto" class="form-control" accept="image/jpeg,image/png,image/webp"/><small class="text-secondary">Leave empty to keep the current photo. Max 5 MB.</small><span asp-validation-for="NewPhoto" class="text-danger small d-block"></span></div><div class="mb-4"><label asp-for="Bio" class="form-label fw-semibold"></label><textarea asp-for="Bio" class="form-control" rows="6"></textarea><span asp-validation-for="Bio" class="text-danger small"></span></div><button class="btn btn-primary px-4">Save changes</button></form></section></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
