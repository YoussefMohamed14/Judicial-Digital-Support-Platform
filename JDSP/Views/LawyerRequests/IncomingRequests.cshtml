@*
    // this is for test only and will be changed later
*@

@model IEnumerable<JDSP.ViewModel.RespondToRequestViewModel>
@{
    ViewData["Title"] = "Incoming Requests";
}

<div class="container mt-4">
    <h2 class="mb-1">Incoming Requests</h2>
    <p class="text-muted mb-4">Cases waiting for your response.</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">No pending requests.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var req in Model)
            {
                <div class="col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title mb-1">@req.CaseName</h5>
                            <p class="text-muted small mb-3">Client: @req.ClientName</p>

                            <form asp-action="Respond" method="post" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="CaseLawyerID" value="@req.CaseLawyerID" />
                                <input type="hidden" name="CaseName" value="@req.CaseName" />
                                <input type="hidden" name="ClientName" value="@req.ClientName" />

                                <button type="submit" name="Decision" value="Accepted"
                                        class="btn btn-success btn-sm flex-fill">
                                    ✓ Accept
                                </button>
                                <button type="submit" name="Decision" value="Rejected"
                                        class="btn btn-danger btn-sm flex-fill">
                                    ✗ Reject
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>