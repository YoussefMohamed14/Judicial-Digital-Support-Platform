@using System.Globalization
@model JDSP.ViewModels.Settings.SettingsViewModel
@{ Layout = User.IsInRole("Lawyer") ? "_LawyerLayout" : "_ClientLayout"; ViewData["Title"] = "Settings"; var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar"; }
<div class="page-head"><span class="eyebrow">@(ar ? "الحساب" : "Account")</span><h1>@(ar ? "الإعدادات" : "Settings")</h1><p>@(ar ? "تحكم في البريد واللغة والمظهر." : "Control your email, language, and appearance.")</p></div>
<div class="settings-stack">
<section class="card-panel"><div class="setting-title"><b>@@</b><div><h2>@(ar ? "تغيير البريد الإلكتروني" : "Change email")</h2><p>@(ar ? "البريد الحالي" : "Current email"): <strong>@Model.CurrentEmail</strong></p></div></div><form asp-action="ChangeEmail" method="post">@Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary-valid"></div><div class="row g-3 align-items-end"><div class="col-md-5"><label asp-for="NewEmail" class="form-label fw-semibold">@(ar ? "البريد الجديد" : "New email")</label><input asp-for="NewEmail" class="form-control"/><span asp-validation-for="NewEmail" class="text-danger small"></span></div><div class="col-md-5"><label asp-for="CurrentPassword" class="form-label fw-semibold">@(ar ? "كلمة المرور الحالية" : "Current password")</label><input asp-for="CurrentPassword" class="form-control"/><span asp-validation-for="CurrentPassword" class="text-danger small"></span></div><div class="col-md-2 d-grid"><button class="btn btn-primary">@(ar ? "تحديث" : "Update")</button></div></div></form></section>
<section class="card-panel"><div class="setting-title"><b>文</b><div><h2>@(ar ? "اللغة" : "Language")</h2><p>@(ar ? "اختر لغة واجهة المنصة." : "Choose the interface language.")</p></div></div><form asp-action="ChangeLanguage" method="post" class="language-grid">@Html.AntiForgeryToken()<input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString"/><label class="language-option @(Model.PreferredLanguage == "en" ? "selected" : "")"><input type="radio" name="language" value="en" checked="@(Model.PreferredLanguage == "en")"/><b>EN</b><span><strong>English</strong><small>Left-to-right</small></span></label><label class="language-option @(Model.PreferredLanguage == "ar" ? "selected" : "")"><input type="radio" name="language" value="ar" checked="@(Model.PreferredLanguage == "ar")"/><b>AR</b><span><strong>العربية</strong><small>من اليمين إلى اليسار</small></span></label><button class="btn btn-outline-primary">@(ar ? "حفظ اللغة" : "Save language")</button></form></section>
<section class="card-panel"><div class="setting-title"><b>◐</b><div><h2>@(ar ? "المظهر" : "Appearance")</h2><p>@(ar ? "اختر الوضع الفاتح أو الداكن." : "Choose light or dark mode.")</p></div></div><div class="theme-grid"><button type="button" class="theme-option" data-theme-choice="light"><span class="theme-preview light"></span><strong>@(ar ? "فاتح" : "Light mode")</strong></button><button type="button" class="theme-option" data-theme-choice="dark"><span class="theme-preview dark"></span><strong>@(ar ? "داكن" : "Dark mode")</strong></button></div></section>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
