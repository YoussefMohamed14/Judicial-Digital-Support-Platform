@using System.Globalization
@{
    Layout = "_PublicLayout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = ar ? "تم تجهيز رابط الاستعادة" : "Reset link ready";
    var resetLink = TempData["PasswordResetLink"] as string;
}
<section class="auth-section"><div class="container py-5"><div class="auth-card mx-auto">
    <div class="text-center mb-4">
        <div class="auth-icon">✓</div>
        <h1 class="h3 fw-bold mt-3">@(ar ? "تحقق من طلب الاستعادة" : "Check your reset request")</h1>
        <p class="text-secondary">@(ar ? "إذا كان البريد موجوداً، يمكن استخدام رابط إعادة تعيين كلمة المرور." : "If the email exists, a password reset link can be used.")</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(resetLink)) {
        <div class="alert alert-info">
            <strong>@(ar ? "وضع التطوير" : "Development mode")</strong>
            <p class="mb-2">@(ar ? "لم يتم ربط خدمة بريد بعد، لذلك يظهر الرابط هنا لتجربة الفريق." : "No email sender is connected yet, so the link is shown here for team testing.")</p>
            <a href="@resetLink" class="btn btn-primary w-100">@(ar ? "فتح رابط إعادة التعيين" : "Open reset link")</a>
        </div>
    }

    <p class="text-center text-secondary mt-4 mb-0">
        <a asp-action="Login" class="fw-semibold text-decoration-none">@(ar ? "الرجوع لتسجيل الدخول" : "Back to sign in")</a>
    </p>
</div></div></section>
