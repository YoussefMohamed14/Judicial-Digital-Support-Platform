@using System.Globalization
@model JDSP.ViewModels.Account.ChangeTemporaryPasswordViewModel
@{
    Layout = "_PublicLayout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = ar ? "تغيير كلمة المرور" : "Change password";
}
<section class="auth-section"><div class="container py-5"><div class="auth-card mx-auto">
    <div class="text-center mb-4">
        <div class="icon-badge mx-auto mb-3">🔐</div>
        <h1 class="h3 fw-bold">@(ar ? "غيّر كلمة المرور المؤقتة" : "Change your temporary password")</h1>
        <p class="text-secondary">@(ar ? "يجب تغيير كلمة المرور التي أنشأها المدير العام قبل استخدام لوحة موظف المحكمة." : "You must change the password created by the super admin before using the court employee dashboard.")</p>
    </div>
    <form asp-action="ChangeTemporaryPassword" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <div class="mb-3"><label asp-for="CurrentPassword" class="form-label fw-semibold">@(ar ? "كلمة المرور الحالية" : "Current password")</label><input asp-for="CurrentPassword" class="form-control" autocomplete="current-password"/><span asp-validation-for="CurrentPassword" class="text-danger small"></span></div>
        <div class="mb-3"><label asp-for="NewPassword" class="form-label fw-semibold">@(ar ? "كلمة المرور الجديدة" : "New password")</label><input asp-for="NewPassword" class="form-control" autocomplete="new-password"/><span asp-validation-for="NewPassword" class="text-danger small"></span><small class="text-secondary">@(ar ? "حرف كبير، حرف صغير، رقم، ورمز." : "Uppercase, lowercase, number, and symbol.")</small></div>
        <div class="mb-4"><label asp-for="ConfirmNewPassword" class="form-label fw-semibold">@(ar ? "تأكيد كلمة المرور الجديدة" : "Confirm new password")</label><input asp-for="ConfirmNewPassword" class="form-control" autocomplete="new-password"/><span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span></div>
        <button class="btn btn-primary btn-lg w-100">@(ar ? "تغيير كلمة المرور" : "Change password")</button>
    </form>
</div></div></section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
