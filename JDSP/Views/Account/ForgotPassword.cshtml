@using System.Globalization
@model JDSP.ViewModels.Account.ForgotPasswordViewModel
@{
    Layout = "_PublicLayout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = ar ? "نسيت كلمة المرور" : "Forgot password";
}
<section class="auth-section"><div class="container py-5"><div class="auth-card mx-auto">
    <div class="text-center mb-4">
        <div class="auth-icon">🔑</div>
        <h1 class="h3 fw-bold mt-3">@(ar ? "استعادة كلمة المرور" : "Reset your password")</h1>
        <p class="text-secondary">@(ar ? "اكتب بريد حسابك وسنجهز لك رابط إعادة تعيين كلمة المرور." : "Enter your account email and we will prepare a password reset link.")</p>
    </div>

    <form asp-action="ForgotPassword" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <div class="mb-4">
            <label asp-for="Email" class="form-label fw-semibold">@(ar ? "البريد الإلكتروني" : "Email")</label>
            <input asp-for="Email" class="form-control form-control-lg" autocomplete="email" placeholder="name@example.com" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>
        <button class="btn btn-primary btn-lg w-100" type="submit">@(ar ? "إرسال رابط الاستعادة" : "Send reset link")</button>
    </form>

    <p class="text-center text-secondary mt-4 mb-0">
        <a asp-action="Login" class="fw-semibold text-decoration-none">@(ar ? "الرجوع لتسجيل الدخول" : "Back to sign in")</a>
    </p>
</div></div></section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
