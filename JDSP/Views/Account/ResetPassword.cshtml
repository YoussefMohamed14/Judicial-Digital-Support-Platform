@using System.Globalization
@model JDSP.ViewModels.Account.ResetPasswordViewModel
@{
    Layout = "_PublicLayout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = ar ? "إعادة تعيين كلمة المرور" : "Reset password";
}
<section class="auth-section"><div class="container py-5"><div class="auth-card mx-auto">
    <div class="text-center mb-4">
        <div class="auth-icon">🔒</div>
        <h1 class="h3 fw-bold mt-3">@(ar ? "اختر كلمة مرور جديدة" : "Choose a new password")</h1>
        <p class="text-secondary">@(ar ? "استخدم كلمة مرور قوية لتأمين حسابك." : "Use a strong password to secure your account.")</p>
    </div>

    <form asp-action="ResetPassword" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Email" type="hidden" />
        <input asp-for="Token" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label fw-semibold">@(ar ? "كلمة المرور الجديدة" : "New password")</label>
            <input asp-for="NewPassword" class="form-control form-control-lg" autocomplete="new-password" />
            <span asp-validation-for="NewPassword" class="text-danger small"></span>
            <small class="text-secondary">@(ar ? "حرف كبير، حرف صغير، رقم، ورمز." : "Uppercase, lowercase, number, and symbol.")</small>
        </div>
        <div class="mb-4">
            <label asp-for="ConfirmNewPassword" class="form-label fw-semibold">@(ar ? "تأكيد كلمة المرور" : "Confirm password")</label>
            <input asp-for="ConfirmNewPassword" class="form-control form-control-lg" autocomplete="new-password" />
            <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
        </div>
        <button class="btn btn-primary btn-lg w-100" type="submit">@(ar ? "حفظ كلمة المرور" : "Save password")</button>
    </form>
</div></div></section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
