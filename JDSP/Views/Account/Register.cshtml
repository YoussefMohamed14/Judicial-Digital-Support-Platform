@using System.Globalization
@model JDSP.ViewModels.Account.RegisterViewModel
@{
    Layout = "_PublicLayout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = ar ? "إنشاء حساب" : "Create account";
}
<section class="auth-section"><div class="container py-5"><div class="auth-card auth-wide mx-auto">
<div class="progress-steps mb-4"><div class="active"><span>1</span><b>@(ar ? "بيانات الحساب" : "Account details")</b></div><i></i><div><span>2</span><b>@(ar ? "الصورة والنبذة" : "Photo and bio")</b></div></div>
<div class="text-center mb-4"><h1 class="h3 fw-bold">@(ar ? "أنشئ حسابك على JDSP" : "Create your JDSP account")</h1><p class="text-secondary">@(ar ? "استخدم البيانات كما تظهر في مستنداتك الرسمية." : "Use the information shown on your official documents.")</p></div>
<form asp-action="Register" method="post" enctype="multipart/form-data">@Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary-valid"></div>
<div class="row g-3">
<div class="col-md-4"><label asp-for="FirstName" class="form-label fw-semibold">@(ar ? "الاسم الأول" : "First name")</label><input asp-for="FirstName" class="form-control"/><span asp-validation-for="FirstName" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="MiddleName" class="form-label fw-semibold">@(ar ? "الاسم الأوسط" : "Middle name")</label><input asp-for="MiddleName" class="form-control"/><span asp-validation-for="MiddleName" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="LastName" class="form-label fw-semibold">@(ar ? "اسم العائلة" : "Last name")</label><input asp-for="LastName" class="form-control"/><span asp-validation-for="LastName" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Email" class="form-label fw-semibold">@(ar ? "البريد الإلكتروني" : "Email")</label><input asp-for="Email" class="form-control" autocomplete="email"/><span asp-validation-for="Email" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="PhoneNumber" class="form-label fw-semibold">@(ar ? "رقم الهاتف" : "Phone number")</label><input asp-for="PhoneNumber" class="form-control"/><span asp-validation-for="PhoneNumber" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="NationalNumber" class="form-label fw-semibold">@(ar ? "الرقم القومي" : "National number")</label><input asp-for="NationalNumber" class="form-control" maxlength="20"/><span asp-validation-for="NationalNumber" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Role" class="form-label fw-semibold">@(ar ? "سجل كـ" : "Register as")</label><select asp-for="Role" asp-items="ViewBag.Roles" class="form-select" id="roleSelect"><option value="">@(ar ? "اختر الدور" : "Select role")</option></select><span asp-validation-for="Role" class="text-danger small"></span></div>

<div class="col-12" id="lawyerVerificationBox" style="display:none">
    <div class="border rounded-4 p-3 mt-2">
        <h2 class="h6 fw-bold mb-1">@(ar ? "مستندات اعتماد المحامي" : "Lawyer verification documents")</h2>
        <p class="text-secondary small mb-3">@(ar ? "يجب رفع بطاقة الرقم القومي وإثبات قيد/كارنيه المحاماة. لن يتم تفعيل حساب المحامي إلا بعد موافقة موظف المحكمة." : "Upload your national/legal ID and lawyer ID/proof. A court employee must approve the account before the lawyer workspace is available.")</p>
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="NationalIdFile" class="form-label fw-semibold">@(ar ? "بطاقة الرقم القومي / الهوية القانونية" : "National / legal ID")</label><input asp-for="NationalIdFile" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.webp,application/pdf,image/jpeg,image/png,image/webp"/><span asp-validation-for="NationalIdFile" class="text-danger small"></span></div>
            <div class="col-md-6"><label asp-for="LawyerIdFile" class="form-label fw-semibold">@(ar ? "كارنيه المحامي / إثبات القيد" : "Lawyer ID / proof")</label><input asp-for="LawyerIdFile" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.webp,application/pdf,image/jpeg,image/png,image/webp"/><span asp-validation-for="LawyerIdFile" class="text-danger small"></span></div>
        </div>
        <small class="text-secondary d-block mt-2">@(ar ? "الصيغ المسموحة: PDF أو JPG أو PNG أو WEBP · الحد الأقصى 10 ميجابايت لكل ملف." : "Allowed: PDF, JPG, PNG or WEBP · Max 10 MB per file.")</small>
    </div>
</div>

<div class="col-md-6"><label asp-for="Password" class="form-label fw-semibold">@(ar ? "كلمة المرور" : "Password")</label><input asp-for="Password" class="form-control" autocomplete="new-password"/><span asp-validation-for="Password" class="text-danger small"></span><small class="text-secondary">@(ar ? "حرف كبير، حرف صغير، رقم، ورمز." : "Uppercase, lowercase, number, and symbol.")</small></div>
<div class="col-md-6"><label asp-for="ConfirmPassword" class="form-label fw-semibold">@(ar ? "تأكيد كلمة المرور" : "Confirm password")</label><input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password"/><span asp-validation-for="ConfirmPassword" class="text-danger small"></span></div>
</div><button class="btn btn-primary btn-lg w-100 mt-4">@(ar ? "المتابعة" : "Continue")</button></form>
<p class="text-center text-secondary mt-4 mb-0">@(ar ? "لديك حساب بالفعل؟" : "Already have an account?") <a asp-action="Login" class="fw-semibold text-decoration-none">@(ar ? "تسجيل الدخول" : "Sign in")</a></p>
</div></div></section>
@section Scripts { <partial name="_ValidationScriptsPartial" />
<script>
(function(){
    const select = document.getElementById('roleSelect');
    const box = document.getElementById('lawyerVerificationBox');
    const toggle = () => { if (box) box.style.display = select && select.value === 'Lawyer' ? '' : 'none'; };
    select?.addEventListener('change', toggle);
    toggle();
})();
</script>
}
