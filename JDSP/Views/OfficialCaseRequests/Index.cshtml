@model IReadOnlyList<JDSP.ViewModels.OfficialCaseRequests.OfficialCaseRequestListItemViewModel>
@{
    Layout = "_CourtLayout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    var status = ViewBag.Status as string;
    ViewData["Title"] = ar ? "طلبات القضايا الرسمية" : "Official case requests";
}

<div class="page-head">
    <span class="eyebrow">@(ar ? "مراجعة المحكمة" : "Court review")</span>
    <h1>@(ar ? "طلبات القضايا الرسمية" : "Official case requests")</h1>
    <p>@(ar ? "راجع طلبات المحامين وجدول الجلسات الرسمية." : "Review lawyer requests and schedule official hearings.")</p>
</div>

<div class="filters">
    <a asp-action="Index" class="@(string.IsNullOrWhiteSpace(status) ? "active" : "")">@(ar ? "الكل" : "All")</a>
    @foreach (var item in new[] { "Pending", "Approved", "Rejected" }) {
        <a asp-action="Index" asp-route-status="@item" class="@(status == item ? "active" : "")">@UiText.Status(item, ar)</a>
    }
    <a asp-action="HearingFollowUps">@(ar ? "متابعة الجلسات المنتهية" : "Ended hearing follow-up")</a>
</div>

<section class="card-panel">
    @if (!Model.Any()) {
        <div class="empty compact"><b>✓</b><p>@(ar ? "لا توجد طلبات حالياً." : "No requests right now.")</p></div>
    }
    else {
        <div class="table-responsive">
            <table class="table clean-table align-middle">
                <thead><tr><th>@(ar ? "القضية" : "Case")</th><th>@(ar ? "المحامي" : "Lawyer")</th><th>@(ar ? "العميل" : "Client")</th><th>@(ar ? "الحالة" : "Status")</th><th>@(ar ? "تاريخ الطلب" : "Requested")</th><th></th></tr></thead>
                <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td class="fw-semibold">@item.CaseName</td>
                        <td>@item.LawyerName</td>
                        <td>@item.ClientName</td>
                        <td><span class="status @item.Status.ToLower()">@UiText.Status(item.Status, ar)</span></td>
                        <td>@item.RequestedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end"><a asp-action="Details" asp-route-id="@item.RequestId" class="btn btn-sm btn-outline-primary">@(ar ? "تفاصيل" : "Details")</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
