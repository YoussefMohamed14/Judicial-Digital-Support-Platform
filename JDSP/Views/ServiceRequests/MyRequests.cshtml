@model IReadOnlyList<JDSP.ViewModels.ServiceRequests.ServiceRequestListItemViewModel>
@{
    Layout = "_ClientLayout";
    var ar = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    ViewData["Title"] = ar ? "طلباتي" : "My requests";
    var filter = ViewBag.TypeFilter as string;
}

<div class="page-head d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div><span class="eyebrow">@(ar ? "الطلبات" : "Requests")</span><h1>@(ar ? "طلباتي" : "My requests")</h1><p>@(ar ? "تابع الطلبات المباشرة المرسلة للمحامين والطلبات العامة المفتوحة للعروض." : "Track direct requests sent to lawyers and public requests open for proposals.")</p></div>
    <div class="d-flex gap-2"><a asp-action="CreatePublic" class="btn btn-primary">@(ar ? "+ طلب عام" : "+ Public request")</a><a asp-controller="Lawyers" asp-action="Index" class="btn btn-outline-primary">@(ar ? "ابحث عن محامٍ" : "Find lawyer")</a></div>
</div>

<div class="filters"><a asp-action="MyRequests" class="@(string.IsNullOrWhiteSpace(filter) ? "active" : "")">@(ar ? "الكل" : "All")</a><a asp-action="MyRequests" asp-route-type="Direct" class="@(filter == "Direct" ? "active" : "")">@UiText.RequestType("Direct", ar)</a><a asp-action="MyRequests" asp-route-type="Public" class="@(filter == "Public" ? "active" : "")">@UiText.RequestType("Public", ar)</a></div>

@if (Model.Count == 0) {
    <section class="card-panel empty"><b>⇄</b><h3>@(ar ? "لا توجد طلبات بعد" : "No requests yet")</h3><p>@(ar ? "اختر محامياً لطلب مباشر أو انشر طلباً ليشاهده أكثر من محامٍ." : "Choose a lawyer for a direct request or publish a request for multiple lawyers.")</p></section>
}
else {
    <div class="row g-4">
    @foreach (var item in Model) {
        <div class="col-md-6 col-xl-4"><article class="case-card request-card">
            <div class="d-flex justify-content-between align-items-start gap-2"><span class="request-type">@UiText.RequestType(item.RequestType, ar)</span><span class="status @item.Status.ToLower().Replace(" ", "-")">@UiText.Status(item.Status, ar)</span></div>
            <h2>@item.Subject</h2>
            <p class="case-desc">@item.Brief</p>
            <div class="case-meta">
                <div><span>@(item.RequestType == "Direct" ? (ar ? "المحامي" : "Lawyer") : (ar ? "العروض" : "Proposals"))</span><strong>@(item.RequestType == "Direct" ? (item.LawyerName ?? (ar ? "غير متاح" : "Not available")) : item.ProposalCount.ToString())</strong></div>
                <div><span>@(ar ? "تاريخ الإرسال" : "Sent")</span><strong>@item.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</strong></div>
                <div><span>@(ar ? "الملف" : "File")</span><strong>@(item.OriginalFileName ?? (ar ? "لا يوجد ملف" : "No file"))</strong></div>
            </div>
            <a asp-action="Details" asp-route-id="@item.RequestId" class="btn btn-outline-primary mt-3">@(ar ? "عرض الطلب" : "View request")</a>
        </article></div>
    }
    </div>
}
