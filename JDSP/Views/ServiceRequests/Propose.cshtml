@model JDSP.ViewModels.ServiceRequests.PublicRequestProposalViewModel
@{ Layout = "_LawyerLayout"; ViewData["Title"] = "Send proposal"; }

<div class="page-head"><span class="eyebrow">Public request proposal</span><h1>@Model.Subject</h1><p>Send your offer to @Model.ClientName. The client can review it from their request page.</p></div>
<div class="row justify-content-center"><div class="col-xl-8"><section class="card-panel"><form asp-action="Propose" method="post">@Html.AntiForgeryToken()<input asp-for="RequestId" type="hidden"/><div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary-valid"></div><div class="mb-3"><label asp-for="Message" class="form-label fw-semibold"></label><textarea asp-for="Message" class="form-control" rows="8" placeholder="Explain your relevant experience, approach, and next steps..."></textarea><span asp-validation-for="Message" class="text-danger small"></span></div><div class="mb-4"><label asp-for="ProposedPrice" class="form-label fw-semibold"></label><input asp-for="ProposedPrice" class="form-control" placeholder="Optional"/><span asp-validation-for="ProposedPrice" class="text-danger small"></span></div><div class="d-flex gap-2"><button class="btn btn-primary px-4">Send proposal</button><a asp-action="PublicRequests" class="btn btn-outline-secondary">Cancel</a></div></form></section></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
